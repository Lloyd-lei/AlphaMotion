{
  "optim": {
    "lr": 0.0003,
    "weight_decay": 1e-05,
    "betas": [
      0.9,
      0.95
    ],
    "warmup_steps": 1000,
    "total_steps": 60000
  },
  "batch": {
    "size": 32,
    "grad_accum": 1
  },
  "loss": {
    "pos_weight": 10.0,
    "rot_weight": 1.0,
    "root_weight": 2.0,
    "fk_weight": 2.0
  },
  "masking": {
    "modes": [
      "random",
      "joint",
      "time",
      "keyframe"
    ],
    "random_p": 0.3,
    "keyframe_p": 0.1
  },
  "eval": {
    "every_steps": 2000,
    "amass_heldout_batches": 64
  },
  "io": {
    "log_every": 100,
    "save_every": 5000,
    "ckpt_keep_last": 3
  }
}